{
  "effortLevel": "xhigh",
  "fallbackModel": ["claude-sonnet-5", "claude-haiku-4-5"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/session-start-fable-tripwire.sh\"",
            "statusMessage": "phase-67.5 tripwire: warn if the Fable window pin outlives 2026-07-12 (masterplan 67.4). fallbackModel note: the chain above covers OVERLOAD-class failures only -- rate/usage-limit cutoffs never switch models (v2.1.199 partial-work retention covers those)."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/pre-tool-use-danger.sh\"",
            "statusMessage": "PreToolUse danger guard..."
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/config-change-audit.sh\"",
            "statusMessage": "Auditing config change... [phase-40.2: alwaysLoad per-server config lives in .mcp.json; continueOnBlock applies to prompt-type hooks per Claude Code v2.1.139 schema -- see CLAUDE.md MCP discipline + Hook continueOnBlock sections]"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/instructions-loaded-research-gate.sh\"",
            "statusMessage": "Reloading research-gate rule..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/post-commit-changelog.sh\"",
            "statusMessage": "Syncing changelog..."
          }
        ]
      },
      {
        "matcher": "Write",
        "if": "Write(.claude/masterplan.json)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/masterplan-memory-sync.sh\"",
            "statusMessage": "Syncing masterplan to memory..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/archive-handoff.sh\"",
            "statusMessage": "Archiving handoff files..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/commit-reminder.sh\"",
            "statusMessage": "Checking commit state..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/auto-commit-and-push.sh\"",
            "statusMessage": "Auto-commit + push on step-done..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "if": "Edit(.claude/masterplan.json)",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/masterplan-memory-sync.sh\"",
            "statusMessage": "Syncing masterplan to memory..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/archive-handoff.sh\"",
            "statusMessage": "Archiving handoff files..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/commit-reminder.sh\"",
            "statusMessage": "Checking commit state..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/auto-commit-and-push.sh\"",
            "statusMessage": "Auto-commit + push on step-done..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$(pwd)}/.claude/hooks/teammate-idle-check.sh\"",
            "statusMessage": "Checking masterplan for active steps..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Before Claude stops, check .claude/masterplan.json for all 'in-progress' steps. For each, run cross-verification. If ANY in-progress step has unfinished verification criteria, return {\"ok\": false, \"reason\": \"Step X.Y incomplete: [details]\"}. If stop_hook_active is true in your context, return {\"ok\": true, \"reason\": \"loop prevention\"} to prevent infinite loop. Otherwise verify and return accordingly.",
            "timeout": 55,
            "asyncRewake": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [ \"${stop_hook_active:-false}\" = true ]; then echo \"{\\\"ok\\\": true, \\\"reason\\\": \\\"loop prevention\\\"}\"; exit 0; fi; echo \"{\\\"ok\\\": true, \\\"reason\\\": \\\"subagent stopped\\\"}\"'",
            "statusMessage": "SubagentStop gate..."
          }
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Write(.claude/context/sessions/**)",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "mcp__alpaca__place_stock_order",
      "mcp__alpaca__place_crypto_order",
      "mcp__alpaca__place_option_order",
      "mcp__alpaca__cancel_order_by_id",
      "mcp__alpaca__cancel_all_orders",
      "mcp__alpaca__replace_order_by_id",
      "mcp__alpaca__close_position",
      "mcp__alpaca__close_all_positions",
      "mcp__alpaca__exercise_options_position",
      "mcp__alpaca__do_not_exercise_options_position",
      "mcp__alpaca__update_account_config",
      "mcp__bigquery__execute-query",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git push*--force*)",
      "Bash(git push* -f *)",
      "Bash(git push* +*)",
      "Bash(launchctl bootout*com.pyfinagent*)",
      "Bash(launchctl unload*com.pyfinagent*)",
      "Bash(launchctl remove*com.pyfinagent*)",
      "Bash(launchctl disable*com.pyfinagent*)"
    ]
  }
}