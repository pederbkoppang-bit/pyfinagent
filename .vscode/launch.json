{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend: FastAPI (.venv312)",
            "type": "python",
            "request": "launch",
            "python": "${workspaceFolder}/.venv312/Scripts/python.exe",
            "module": "uvicorn",
            "args": [
                "backend.main:app",
                "--host",
                "127.0.0.1",
                "--port",
                "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "jinja": true,
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Frontend: Next.js",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/frontend"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Backend + Frontend",
            "configurations": [
                "Backend: FastAPI (.venv312)",
                "Frontend: Next.js"
            ],
            "stopAll": true
        }
    ]
}
